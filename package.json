{
  "name": "uask-qa-automation",
  "version": "1.0.0",
  "description": "U-Ask conversational QA automation for UAE government chatbot validation",
  "scripts": {
    "setup": "npm install && npx playwright install chromium webkit",
    "test": "USE_MOCK=true playwright test",
    "test:ui": "playwright test tests/ui",
    "test:ai": "playwright test tests/ai",
    "test:security": "playwright test tests/security",
    "test:mock": "USE_MOCK=true playwright test",
    "test:live": "USE_MOCK=false playwright test",
    "report": "playwright show-report",
    "report:summary": "node scripts/report-summary.mjs"
  },
  "keywords": ["u-ask", "playwright", "qa", "ai-testing"],
  "license": "ISC",
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@playwright/test": "^1.60.0",
    "@types/node": "^20.14.4",
    "dotenv": "^17.4.2",
    "openai": "^6.38.0",
    "typescript": "^6.0.3"
  }
}
